{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Context Studio",
  "version": "1.1.1",
  "identifier": "com.sahil.context-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Context Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "nsis",
      "dmg"
    ],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/com.sahil.context-studio.metainfo.xml": "com.sahil.context-studio.metainfo.xml"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/metainfo/com.sahil.context-studio.metainfo.xml": "com.sahil.context-studio.metainfo.xml"
        }
      }
    }
  }
}